# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/

# IDE / editor
.vscode/
.idea/
*.swp
.DS_Store

# Secrets — never commit. env.yaml here would only appear if a user runs the
# job locally; the production secrets live in Secret Manager.
.env
env.yaml
*.token.json
credentials.json

# Local pipeline state and exported article data — contain article text and
# may contain PII from email newsletters. Must never end up in git or in a
# Docker build context (see .dockerignore for the same rules).
pipeline.db
pipeline.db-journal
pipeline.db-wal
pipeline.db-shm
*.db
articles.csv
articles.json
temp/

# VCS metadata (defensive; only meaningful when this folder is a sub-tree
# of a larger workspace and another tool tars it up).
.git/
